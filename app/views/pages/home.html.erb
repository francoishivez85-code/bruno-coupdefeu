<%# Page d'accueil réduite Hero sombre + appel à Nono! %>
<section class="cdf-home-hero d-flex flex-column align-items-center justify-content-center text-center">

  <%# Braises flottantes — pure CSS, pas de JS %>
  <span class="cdf-ember" style="--l:6%;  --d:14px;  --s:3px; --delay:0s;   --dur:7s"></span>
  <span class="cdf-ember" style="--l:14%; --d:-18px; --s:2px; --delay:2.3s; --dur:5s"></span>
  <span class="cdf-ember" style="--l:22%; --d:22px;  --s:4px; --delay:0.8s; --dur:8s"></span>
  <span class="cdf-ember" style="--l:31%; --d:-10px; --s:2px; --delay:4.1s; --dur:6s"></span>
  <span class="cdf-ember" style="--l:38%; --d:28px;  --s:3px; --delay:1.5s; --dur:9s"></span>
  <span class="cdf-ember" style="--l:47%; --d:-22px; --s:5px; --delay:3.0s; --dur:7s"></span>
  <span class="cdf-ember" style="--l:53%; --d:16px;  --s:2px; --delay:0.3s; --dur:5s"></span>
  <span class="cdf-ember" style="--l:61%; --d:-26px; --s:4px; --delay:5.5s; --dur:8s"></span>
  <span class="cdf-ember" style="--l:69%; --d:12px;  --s:2px; --delay:2.0s; --dur:6s"></span>
  <span class="cdf-ember" style="--l:76%; --d:-14px; --s:3px; --delay:4.7s; --dur:7s"></span>
  <span class="cdf-ember" style="--l:83%; --d:20px;  --s:2px; --delay:1.1s; --dur:9s"></span>
  <span class="cdf-ember" style="--l:91%; --d:-18px; --s:4px; --delay:3.6s; --dur:6s"></span>

  <%= image_tag "logo-white.png", alt: "Coup de Feu", class: "cdf-home-logo mb-4" %>
  <h1 class="hero-headline mb-3">Le renfort qui arrive avant le coup de feu.</h1>
  <p class="cdf-home-sub lead mb-4">
    Une question, un renfort urgent&nbsp;? Demandez à <strong>Bruno</strong> !
  </p>
  <p class="cdf-home-hint">
    Bruno vous attend en bas à droite <i class="fa-solid fa-arrow-down cdf-arrow-oblique ms-1"></i>
  </p>
</section>

<%= render "shared/bruno" %>
