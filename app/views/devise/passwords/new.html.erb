<div class="cdf-neon-login">
  <div class="cdf-neon-card">
    <h2 class="login-title mb-2">Mot de passe oublié ?</h2>
    <p class="text-center mb-4">On vous envoie un lien pour le réinitialiser.</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Email",
                    input_html: { autocomplete: "email", placeholder: "vous@exemple.com" } %>
      </div>

      <div class="form-actions d-grid mt-4">
        <%= f.button :submit, "Envoyer le lien de réinitialisation", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>

    <hr class="my-4">
    <div class="text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
