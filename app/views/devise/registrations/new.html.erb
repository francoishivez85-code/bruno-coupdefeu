<div class="cdf-neon-login">
  <div class="cdf-neon-card">
    <h2 class="login-title">Créer un compte</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Email",
                    input_html: { autocomplete: "email", placeholder: "vous@exemple.com" } %>
        <%= f.input :password,
                    required: true,
                    label: "Mot de passe",
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password", placeholder: "••••••••" } %>
        <%= f.input :password_confirmation,
                    required: true,
                    label: "Confirmation du mot de passe",
                    input_html: { autocomplete: "new-password", placeholder: "••••••••" } %>
      </div>

      <div class="form-actions d-grid mt-4">
        <%= f.button :submit, "S'inscrire", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>

    <hr class="my-4">
    <div class="text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
