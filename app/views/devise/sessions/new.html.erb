<div class="cdf-neon-login">
  <div class="cdf-neon-card">
    <h2 class="login-title">Connexion</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    label: "Email",
                    input_html: { autocomplete: "email" } %>
        <%= f.input :password,
                    required: false,
                    label: "Mot de passe",
                    input_html: { autocomplete: "current-password" } %>
        <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions d-grid mt-4">
        <%= f.button :submit, "Se connecter", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>

    <hr class="my-4">
    <div class="text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
